# Polibio.ai — API keys for the data tools.
# Copy this file to .env and fill ONLY the keys for the sources your study uses.
#
# Most sources need NO key and are omitted here: Eurostat, OECD, World Bank,
# INE, IGE, Banco de España, BOE-BORME, Seguridad Social, Catastro,
# datos.gob.es, ISTAT (SDMX + bulk), US Census / QCEW / BTOS, ONS, BLS.

# --- Claude Code (the agent runtime) ---
ANTHROPIC_API_KEY=

# --- US macro time series (FRED; also wired via .mcp.json) ---
FRED_API_KEY=

# --- United Kingdom ---
COMPANIES_HOUSE_API_KEY=    # free — developer.company-information.service.gov.uk
NOMIS_API_KEY=              # optional — nomisweb.co.uk; works without, just lower rate limits

# --- Patents (EPO Open Patent Services) ---
EPO_OPS_KEY=
EPO_OPS_SECRET=

# --- Korea corporate disclosure (DART) ---
DART_API_KEY=               # free — opendart.fss.or.kr

# --- Maps (optional; only tools/felt-upload.py) ---
FELT_API_TOKEN=
